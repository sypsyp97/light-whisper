{
  "name": "light-whisper",
  "private": true,
  "version": "1.4.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "pnpm lint && pnpm test && pnpm build && pnpm check:bundle",
    "check:bundle": "node scripts/check_bundle_budget.mjs",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "lint": "eslint src --max-warnings=0",
    "perf:fluidity": "vitest run src/perf/appFluidity.perf.test.tsx --reporter=verbose",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --exclude src/perf/** && pnpm perf:fluidity",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "0.17.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-markdown": "10.1.0",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "sonner": "^1.7.0",
    "tauri-plugin-keyring-api": "^0.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
