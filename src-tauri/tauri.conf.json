{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "轻语 Whisper",
  "version": "1.4.1",
  "identifier": "com.light-whisper.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "轻语 Whisper",
        "width": 420,
        "height": 560,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true,
        "url": "/",
        "windowEffects": {
          "effects": [
            "acrylic"
          ],
          "state": "active"
        }
      },
      {
        "label": "selection-toolbar",
        "title": "划词助手",
        "width": 404,
        "height": 54,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "shadow": false,
        "visible": false,
        "url": "/?window=selection"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:",
      "capabilities": ["main", "subtitle", "selection"]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "compression": "none"
      }
    },
    "resources": [
      "resources/funasr_server.py",
      "resources/whisper_server.py",
      "resources/download_models.py",
      "resources/hf_cache_utils.py",
      "resources/server_common.py",
      "resources/engine.tar.xz"
    ]
  }
}
